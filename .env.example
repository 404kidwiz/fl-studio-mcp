# FL Studio MCP — environment variables
# Copy to .env and fill in values

# Set to 1 to enable dry-run mode (no MIDI sent, just preview output)
FL_MCP_DRY_RUN=0

# Default MIDI output port name (partial match is fine)
# macOS default: "IAC Driver Bus 1"
# Windows default: set to your loopMIDI port name
FL_MCP_PORT=IAC Driver Bus 1

# Default MIDI input port name (for receiving acks from FL Studio)
# Leave blank to disable ack listening
FL_MCP_INPUT_PORT=
